{
  "name": "@auth-parts/auth-container-client",
  "private": true,
  "version": "0.1.0",
  "description": "auth-container (https://auth-container.hanacus87.net) 専用の OIDC クライアントライブラリ",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./adapters/hono": {
      "types": "./dist/adapters/hono.d.ts",
      "import": "./dist/adapters/hono.js",
      "require": "./dist/adapters/hono.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "hono": "^4.6.0",
    "jose": "^5.9.0"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "hono": "^4.6.0",
    "jose": "^5.9.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  }
}

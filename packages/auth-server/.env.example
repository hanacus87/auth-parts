PORT=4000
DATABASE_URL=postgresql://oidc:oidc_secret@localhost:5432/oidc_db

# RS256 鍵ペア（初回起動時に自動生成）
PRIVATE_KEY_PATH=./keys/private.pem
PUBLIC_KEY_PATH=./keys/public.pem

# トークン有効期限（秒）
ACCESS_TOKEN_TTL=3600
ID_TOKEN_TTL=3600
REFRESH_TOKEN_TTL=2592000

# OIDC Issuer（外部公開時は実際の URL に変更）
ISSUER=http://localhost:4000

# login_challenge / consent_challenge の署名鍵（本番では十分なランダム文字列に変更）
SESSION_SECRET=change-me-in-production-32chars!!

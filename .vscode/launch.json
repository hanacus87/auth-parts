{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "bun",
      "request": "launch",
      "name": "Auth Server",
      "program": "${workspaceFolder}/packages/auth-server/src/index.ts",
      "cwd": "${workspaceFolder}/packages/auth-server",
      "watchMode": true,
      "stopOnEntry": false
    },
    {
      "type": "bun",
      "request": "launch",
      "name": "App Server",
      "program": "${workspaceFolder}/packages/app-server/src/index.ts",
      "cwd": "${workspaceFolder}/packages/app-server",
      "watchMode": true,
      "stopOnEntry": false
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Frontend (Vite)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["exec", "vite"],
      "cwd": "${workspaceFolder}/packages/frontend",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "bun",
      "request": "launch",
      "name": "App Server Sub",
      "program": "${workspaceFolder}/packages/app-server-sub/src/index.ts",
      "cwd": "${workspaceFolder}/packages/app-server-sub",
      "watchMode": true,
      "stopOnEntry": false
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Frontend Sub (Vite)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["exec", "vite"],
      "cwd": "${workspaceFolder}/packages/frontend-sub",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ],
  "compounds": [
    {
      "name": "All Servers",
      "configurations": [
        "Auth Server",
        "App Server",
        "App Server Sub",
        "Frontend (Vite)",
        "Frontend Sub (Vite)"
      ],
      "stopAll": true
    }
  ]
}

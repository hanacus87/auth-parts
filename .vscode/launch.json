{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Auth Container (wrangler)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["run", "dev:auth"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Auth Frontend (build watch)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["run", "dev:auth-frontend"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "bun",
      "request": "launch",
      "name": "App Server",
      "program": "${workspaceFolder}/packages/app-server/src/index.ts",
      "cwd": "${workspaceFolder}/packages/app-server",
      "watchMode": true,
      "stopOnEntry": false
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Frontend (Vite)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["exec", "vite"],
      "cwd": "${workspaceFolder}/packages/frontend",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "bun",
      "request": "launch",
      "name": "App Server Sub",
      "program": "${workspaceFolder}/packages/app-server-sub/src/index.ts",
      "cwd": "${workspaceFolder}/packages/app-server-sub",
      "watchMode": true,
      "stopOnEntry": false
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Frontend Sub (Vite)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["exec", "vite"],
      "cwd": "${workspaceFolder}/packages/frontend-sub",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ],
  "compounds": [
    {
      "name": "Auth (container + frontend)",
      "configurations": ["Auth Container (wrangler)", "Auth Frontend (build watch)"],
      "stopAll": true
    },
    {
      "name": "App 1 (+ Auth)",
      "configurations": [
        "Auth Container (wrangler)",
        "Auth Frontend (build watch)",
        "App Server",
        "Frontend (Vite)"
      ],
      "stopAll": true
    },
    {
      "name": "App 2 (+ Auth)",
      "configurations": [
        "Auth Container (wrangler)",
        "Auth Frontend (build watch)",
        "App Server Sub",
        "Frontend Sub (Vite)"
      ],
      "stopAll": true
    },
    {
      "name": "All Servers",
      "configurations": [
        "Auth Container (wrangler)",
        "Auth Frontend (build watch)",
        "App Server",
        "App Server Sub",
        "Frontend (Vite)",
        "Frontend Sub (Vite)"
      ],
      "stopAll": true
    }
  ]
}

{
  "name": "auth-container",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev": "wrangler dev --local --port 4000",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy:cf": "wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:reset:local": "wrangler d1 execute DB --local --file=./drizzle/schema.sql",
    "db:reset:remote": "wrangler d1 execute DB --remote --file=./drizzle/schema.sql",
    "db:seed:local": "wrangler d1 execute DB --local --file=./drizzle/seed.sql",
    "db:seed:remote": "wrangler d1 execute DB --remote --file=./drizzle/seed.sql"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.0",
    "hono": "^4.6.0",
    "jose": "^5.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241022.0",
    "drizzle-kit": "^0.28.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.83.0"
  }
}

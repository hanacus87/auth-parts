PORT=3000

# 実行環境。本番では production を指定すること。
# - production: Cookie の Secure 属性を強制 ON。REDIRECT_URI が http:// だと起動時に ConfigError。
# - 未設定 / development: REDIRECT_URI が https:// なら Secure=true、http:// なら Secure=false。
#   ローカル開発で http://localhost を使う場合はここを未設定 (または development) のままにする。
NODE_ENV=development

# OIDC クライアント（auth-container の seed に登録されている値と一致させる）
CLIENT_ID=bff-app
CLIENT_SECRET=bff-app-secret
# 本番は必ず https://。NODE_ENV=production + http:// は起動時に弾かれる。
REDIRECT_URI=http://localhost:3000/auth/callback
FRONTEND_URL=http://localhost:5173

# JWE Cookie 鍵 (32 byte base64)。カンマ区切りで複数指定可 (先頭=現行鍵、末尾=旧鍵)。
# 生成例: openssl rand -base64 32
COOKIE_KEYS=REPLACE_WITH_openssl_rand_base64_32

# BFF セッション Cookie 名。未設定時はライブラリ default 'bff_session' が使われる。
# 同一オリジンに複数 BFF を同居させる場合や、既存運用名を維持したい場合に指定する。
SESSION_COOKIE_NAME=bff_session_app

# OP の logout クエリに渡す post_logout_redirect_uri (任意)。
# - 設定する場合: frontend URL を直接指定 (例: http://localhost:5173)。
#   auth-container 管理画面の「ログアウト後の遷移先 URL」にも同じ値を完全一致で登録すること。
# - 未設定: logout 後ユーザは OP の完了画面に留まる。
POST_LOGOUT_REDIRECT_URI=http://localhost:5173
